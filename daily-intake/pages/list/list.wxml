<nav-bar title="全部记录"></nav-bar>

<view class="page-container">
  <!-- 分类筛选 -->
  <scroll-view scroll-x class="filter-bar">
    <view
      class="filter-chip {{activeFilter === 'all' ? 'active' : ''}}"
      bindtap="onFilter"
      data-filter="all"
    >全部</view>
    <view
      wx:for="{{categories}}"
      wx:key="key"
      class="filter-chip {{activeFilter === item.key ? 'active' : ''}}"
      bindtap="onFilter"
      data-filter="{{item.key}}"
    >
      <text>{{item.icon}} {{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 记录列表按日期分组 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{groupedRecords.length === 0}}" class="empty-state">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无记录</text>
  </view>

  <view wx:else>
    <view wx:for="{{groupedRecords}}" wx:key="date" class="date-group">
      <view class="date-header">
        <text class="date-label">{{item.dateCN}}</text>
        <text class="date-count">{{item.records.length}} 条</text>
      </view>
      <intake-card
        wx:for="{{item.records}}"
        wx:for-item="record"
        wx:key="_id"
        item="{{record}}"
        bind:tap="onCardTap"
      />
    </view>
  </view>
</view>
