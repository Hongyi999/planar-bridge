<nav-bar title="我的"></nav-bar>

<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view wx:if="{{userInfo}}" class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view class="user-detail">
        <text class="nickname">{{userInfo.nickName}}</text>
        <text class="user-hint">记录生活每一天</text>
      </view>
    </view>
    <view wx:else class="login-prompt" bindtap="onLogin">
      <view class="avatar-placeholder">👤</view>
      <view class="user-detail">
        <text class="nickname">点击登录</text>
        <text class="user-hint">登录后数据可云端同步</text>
      </view>
    </view>
  </view>

  <!-- 统计概览 -->
  <view class="stats-card">
    <text class="stats-title">统计概览</text>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-number">{{totalCount}}</text>
        <text class="stat-label">总记录</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{todayCount}}</text>
        <text class="stat-label">今日</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{streakDays}}</text>
        <text class="stat-label">连续天数</text>
      </view>
    </view>
  </view>

  <!-- 分类统计 -->
  <view class="category-stats-card">
    <text class="stats-title">分类统计</text>
    <view wx:for="{{categoryStats}}" wx:key="key" class="category-stat-row">
      <text class="cat-icon">{{item.icon}}</text>
      <text class="cat-name">{{item.name}}</text>
      <view class="cat-bar-bg">
        <view class="cat-bar" style="width: {{item.percent}}%; background: {{item.color}};"></view>
      </view>
      <text class="cat-count">{{item.count}}</text>
    </view>
  </view>
</view>
