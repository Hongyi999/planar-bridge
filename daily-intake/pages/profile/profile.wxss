.user-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}
.user-info, .login-prompt {
  display: flex;
  align-items: center;
}
.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}
.avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}
.nickname {
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--color-text);
  display: block;
}
.user-hint {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  margin-top: 4rpx;
  display: block;
}

.stats-card, .category-stats-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}
.stats-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 24rpx;
}
.stats-grid {
  display: flex;
  text-align: center;
}
.stat-item {
  flex: 1;
}
.stat-number {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
}
.stat-label {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  margin-top: 4rpx;
}

.category-stat-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.category-stat-row:last-child {
  margin-bottom: 0;
}
.cat-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  width: 40rpx;
}
.cat-name {
  font-size: var(--font-sm);
  color: var(--color-text);
  width: 80rpx;
}
.cat-bar-bg {
  flex: 1;
  height: 16rpx;
  background: var(--color-border);
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}
.cat-bar {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
}
.cat-count {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  width: 60rpx;
  text-align: right;
}
