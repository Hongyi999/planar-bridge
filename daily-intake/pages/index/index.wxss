.greeting-section {
  padding: 20rpx 0 32rpx;
}
.greeting-date {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-hint);
}
.greeting-text {
  display: block;
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-text);
  margin-top: 8rpx;
}

/* 分类快捷入口 */
.category-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding-bottom: 8rpx;
}
.category-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
  transition: transform 0.15s ease;
}
.category-chip:active {
  transform: scale(0.95);
}
.chip-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}
.chip-text {
  font-size: var(--font-sm);
  font-weight: 500;
}

/* 记录计数 */
.record-count {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  margin-bottom: 20rpx;
}

/* 列表动画 */
.record-list intake-card {
  opacity: 0;
  animation: fadeInUp 0.4s ease forwards;
}
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: var(--font-lg);
  color: var(--color-text);
  font-weight: 500;
}
.empty-hint {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  margin-top: 12rpx;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 120rpx 0;
  color: var(--color-text-hint);
}

/* 悬浮添加按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(140rpx + var(--safe-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(250, 140, 22, 0.35);
  z-index: 99;
  transition: transform 0.15s ease;
}
.fab:active {
  transform: scale(0.9);
}
.fab-icon {
  font-size: 52rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}
