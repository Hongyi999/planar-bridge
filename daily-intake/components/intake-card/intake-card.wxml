<view class="intake-card" bindtap="onTap" style="border-left: 6rpx solid {{categoryInfo.color}};">
  <view class="card-header">
    <text class="card-icon">{{categoryInfo.icon}}</text>
    <text class="card-category" style="color: {{categoryInfo.color}};">{{categoryInfo.name}}</text>
    <text class="card-time">{{item.createTime}}</text>
  </view>
  <view class="card-title">{{item.title}}</view>
  <view wx:if="{{item.note}}" class="card-note">{{item.note}}</view>
  <view wx:if="{{item.rating}}" class="card-rating">
    <text wx:for="{{ratingStars}}" wx:key="*this" class="star {{item < rating ? 'filled' : ''}}">★</text>
  </view>
</view>
