<view class="tab-bar">
  <view class="tab-bar-inner">
    <view
      wx:for="{{list}}"
      wx:key="index"
      class="tab-item {{selected === index ? 'active' : ''}}"
      bindtap="switchTab"
      data-index="{{index}}"
      data-path="{{item.pagePath}}"
    >
      <text class="tab-icon">{{selected === index ? item.selectedIcon : item.icon}}</text>
      <text class="tab-label">{{item.text}}</text>
    </view>
  </view>
  <view class="safe-area-placeholder"></view>
</view>
