.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  z-index: 100;
}
.tab-bar-inner {
  display: flex;
  padding: 8rpx 0 4rpx;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4rpx 0;
  color: var(--color-text-hint);
  transition: color 0.2s ease;
}
.tab-item.active {
  color: var(--color-primary);
}
.tab-icon {
  font-size: 44rpx;
  height: 48rpx;
  line-height: 48rpx;
}
.tab-label {
  font-size: 20rpx;
  margin-top: 2rpx;
}
.safe-area-placeholder {
  width: 100%;
  height: var(--safe-bottom);
}
