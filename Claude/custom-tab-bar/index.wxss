.tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #F2EFE4;
  border-top: 1rpx solid #E8E3D8;
  position: relative;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  flex: 1;
  padding: 8rpx 0;
  opacity: 0.55;
  transition: opacity 0.2s;
}

.tab-item.active {
  opacity: 1;
}

.tab-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 500;
  font-family: -apple-system, "Helvetica Neue", "PingFang SC", sans-serif;
}