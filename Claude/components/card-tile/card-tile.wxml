<view class="card-tile {{show ? 'show' : ''}}" bindtap="onTap" style="animation-delay: {{index * 100}}ms">
  <!-- Card image placeholder -->
  <view class="card-img" style="background: linear-gradient(135deg, #EBE7DA, #E0DBCC)">
    <view class="card-placeholder font-heading">{{card.name}}</view>
    <!-- Rarity badge -->
    <view class="rarity-badge rarity-{{card.rarity}}">
      {{card.rarity === 'Legendary' ? 'L' : card.rarity === 'Majestic' ? 'M' : card.rarity === 'Rare' ? 'R' : card.rarity === 'Common' ? 'C' : 'F'}}
    </view>
    <!-- Heart button -->
    <view class="heart-btn {{isFav ? 'active' : ''}}" catchtap="onHeartTap">
      <view class="heart-icon"></view>
    </view>
  </view>
  <!-- Card info -->
  <view class="card-info">
    <view class="card-name font-heading">{{card.name}}</view>
    <view class="card-meta">{{card.class}} · {{card.type}}{{card.subtype ? ' — ' + card.subtype : ''}} · {{card.setCode}}</view>
    <view class="card-price-row">
      <text class="card-price font-mono {{card.priceTrend > 0 ? 'price-up' : card.priceTrend < 0 ? 'price-down' : 'price-flat'}}">${{card.priceMid}}</text>
      <text class="card-trend {{card.priceTrend > 0 ? 'price-up' : card.priceTrend < 0 ? 'price-down' : 'price-flat'}}">{{card.priceTrend > 0 ? '▲ ' + card.priceTrend + '%' : card.priceTrend < 0 ? '▼ ' + (-card.priceTrend) + '%' : '— 0%'}}</text>
    </view>
  </view>
</view>
