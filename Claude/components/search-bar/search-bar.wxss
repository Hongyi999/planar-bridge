.search-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FDFCF8;
  border: 3rpx solid #9B864435;
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 40rpx #9B864408;
  transition: border-color 0.3s, box-shadow 0.3s;
}

.search-bar.compact {
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  border-color: #D6D0C2;
  box-shadow: none;
}

.search-icon-img {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.plus-icon {
  opacity: 0.45;
}

.plus-icon:active {
  opacity: 0.8;
}

.mic-icon {
  opacity: 0.35;
  width: 34rpx;
  height: 34rpx;
}

.mic-icon:active {
  opacity: 0.7;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #2C2A22;
  font-family: -apple-system, "Helvetica Neue", "PingFang SC", sans-serif;
  text-align: left;
}

.search-placeholder {
  color: #B8AD96;
  font-size: 26rpx;
}
