.search-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FDFCF8;
  border: 3rpx solid #9B864435;
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 40rpx #9B864408;
  transition: border-color 0.3s, box-shadow 0.3s;
}

.search-bar.compact {
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  border-color: #D6D0C2;
  box-shadow: none;
}

.search-icon-img {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.plus-icon {
  opacity: 0.45;
}

.plus-icon:active {
  opacity: 0.8;
}

.search-input-wrap {
  flex: 1;
  position: relative;
  height: 36rpx;
}

.search-input {
  width: 100%;
  height: 100%;
  font-size: 26rpx;
  color: #2C2A22;
  font-family: -apple-system, "Helvetica Neue", "PingFang SC", sans-serif;
  text-align: left;
  position: relative;
  z-index: 2;
}

/* Animated placeholder */
.placeholder-scroll {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 36rpx;
  overflow: hidden;
  pointer-events: none;
  z-index: 1;
}

.placeholder-track {
  display: flex;
  flex-direction: column;
  transition: none;
}

.placeholder-track.slide-up {
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  transform: translateY(-36rpx);
}

.placeholder-text {
  height: 36rpx;
  line-height: 36rpx;
  font-size: 26rpx;
  color: #B8AD96;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
