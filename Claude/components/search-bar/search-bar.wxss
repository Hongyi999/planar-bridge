.search-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FDFCF8;
  border: 3rpx solid #9B864435;
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 40rpx #9B864408;
  transition: border-color 0.3s, box-shadow 0.3s;
}

.search-bar.compact {
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  border-color: #D6D0C2;
  box-shadow: none;
}

.search-icon-img {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.plus-icon {
  opacity: 0.45;
}

.plus-icon:active {
  opacity: 0.8;
}

.mic-icon {
  opacity: 0.35;
  width: 34rpx;
  height: 34rpx;
}

.mic-icon:active {
  opacity: 0.7;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #2C2A22;
  font-family: -apple-system, "Helvetica Neue", "PingFang SC", sans-serif;
  text-align: left;
}

.search-placeholder {
  color: #B8AD96;
  font-size: 26rpx;
}

/* Recording waveform */
.stop-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.stop-icon {
  width: 20rpx;
  height: 20rpx;
  background: #C74A4A;
  border-radius: 4rpx;
}

.wave-bars {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
  justify-content: center;
  height: 48rpx;
}

.wave-bar {
  width: 6rpx;
  min-height: 8rpx;
  max-height: 48rpx;
  background: #9B8644;
  border-radius: 3rpx;
  transition: height 0.1s ease;
}
