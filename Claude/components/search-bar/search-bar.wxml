<view class="search-bar {{compact ? 'compact' : ''}}" bindtap="onTap">
  <!-- Search icon -->
  <image class="search-icon-img" src="/assets/icons/tab-search.svg" mode="aspectFit" />
  <input
    class="search-input"
    value="{{value}}"
    placeholder="{{placeholder}}"
    placeholder-class="search-placeholder"
    confirm-type="search"
    focus="{{focus}}"
    bindinput="onInput"
    bindconfirm="onConfirm"
  />
</view>
