.hero-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: #F2EFE4;
  position: relative;
  overflow: hidden;
}

/* Grid background */
.bg-lines {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.04;
  background-image:
    repeating-linear-gradient(0deg, transparent, transparent 78rpx, #9B8644 78rpx, #9B8644 80rpx),
    repeating-linear-gradient(90deg, transparent, transparent 78rpx, #9B8644 78rpx, #9B8644 80rpx);
}

/* Glow */
.bg-glow {
  position: absolute;
  top: 35%;
  left: 50%;
  width: 560rpx;
  height: 560rpx;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, #9B864412 0%, transparent 70%);
  pointer-events: none;
}

/* Floating orbs */
.orb {
  position: absolute;
  border-radius: 50%;
  background: #9B8644;
  opacity: 0.15;
}

.orb-1 {
  top: 20%;
  left: 15%;
  width: 12rpx;
  height: 12rpx;
  animation: float 6s ease-in-out infinite;
}

.orb-2 {
  top: 60%;
  right: 12%;
  width: 8rpx;
  height: 8rpx;
  animation: float 8s ease-in-out infinite 1s;
}

.orb-3 {
  top: 35%;
  right: 25%;
  width: 16rpx;
  height: 16rpx;
  opacity: 0.08;
  animation: float 7s ease-in-out infinite 2s;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-30rpx); }
}

/* Content */
.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 640rpx;
  width: 100%;
}

/* Logo */
.logo-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.logo-img {
  width: 48rpx;
  height: 48rpx;
}

.logo-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #9B8644;
  letter-spacing: 0.25em;
  text-transform: uppercase;
}

/* Heading */
.hero-heading {
  font-size: 52rpx;
  font-weight: 700;
  color: #2C2A22;
  line-height: 1.2;
  letter-spacing: -0.01em;
  margin-bottom: 16rpx;
  white-space: pre-line;
}

.hero-sub {
  font-size: 26rpx;
  color: #8C8474;
  line-height: 1.5;
  margin-bottom: 4rpx;
}

.hero-sub-detail {
  font-size: 26rpx;
  color: #8C8474;
  margin-bottom: 56rpx;
}

/* Search */
.hero-search {
  margin-bottom: 36rpx;
}

/* Chips */
.chips-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  justify-content: center;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-family: -apple-system, "Helvetica Neue", "PingFang SC", sans-serif;
}

.chip:active {
  transform: translateY(-2rpx);
}

.chip-gold {
  background: #9B86440D;
  border: 2rpx solid #9B864425;
  color: #8B7A3E;
}

.chip-purple {
  background: #6B4C8A0D;
  border: 2rpx solid #6B4C8A20;
  color: #6B4C8A;
}

.chip-green {
  background: #3D7A5E0D;
  border: 2rpx solid #3D7A5E20;
  color: #3D7A5E;
}
