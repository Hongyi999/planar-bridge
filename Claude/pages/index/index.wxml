<view class="hero-page">
  <!-- Background grid lines -->
  <view class="bg-lines"></view>

  <!-- Center content -->
  <view class="hero-content">
    <!-- Logo -->
    <view class="logo-row">
      <image class="logo-img" src="/assets/icons/logo-bridge.svg" mode="aspectFit" />
      <text class="logo-text font-heading">PLANAR BRIDGE</text>
    </view>

    <!-- Heading -->
    <view class="hero-heading font-heading">你在找什么卡牌？</view>

    <!-- Subtitle -->
    <view class="hero-sub">输入、拍照或说出你想找的卡</view>

    <!-- Search bar -->
    <view class="hero-search">
      <search-bar value="{{searchValue}}" focus="{{searchFocus}}" placeholder="{{searchPlaceholder || '搜索 Ninja 的传奇装备...'}}" recording="{{isRecording}}" bars="{{voiceBars}}" bind:search="onSearch" bind:camera="onCameraSearch" bind:mic="onVoiceSearch" />
    </view>

    <!-- Suggestion chips -->
    <view class="chips-row">
      <view
        wx:for="{{chips}}"
        wx:key="index"
        class="chip chip-{{item.type}}"
        data-query="{{item.query}}"
        data-text="{{item.text}}"
        bindtap="onChipTap"
      >{{item.text}}</view>
    </view>

    <!-- Detail line (moved below chips) -->
    <view class="hero-sub-detail">实时价格 · 系列浏览 · 个人收藏</view>
  </view>
</view>