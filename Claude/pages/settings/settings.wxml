<view class="settings-page">
  <text class="page-title font-heading">设置</text>
  <text class="page-subtitle">应用设置和关于信息</text>

  <!-- Settings groups -->
  <view class="settings-group">
    <view class="group-title">数据管理</view>
    <view class="settings-item" bindtap="onClearCache">
      <view class="item-left">
        <text class="item-label">清除缓存</text>
        <text class="item-desc">当前缓存: {{cacheSize}}</text>
      </view>
      <text class="item-arrow">›</text>
    </view>
  </view>

  <view class="settings-group">
    <view class="group-title">关于</view>
    <view class="settings-item" bindtap="onAbout">
      <view class="item-left">
        <text class="item-label">关于 Planar Bridge</text>
        <text class="item-desc">版本 {{version}}</text>
      </view>
      <text class="item-arrow">›</text>
    </view>
  </view>

  <!-- Footer -->
  <view class="settings-footer">
    <view class="footer-logo">
      <view class="footer-bridge">
        <view class="fb-left"></view>
        <view class="fb-right"></view>
      </view>
    </view>
    <text class="footer-name font-heading">PLANAR BRIDGE</text>
    <text class="footer-tagline">AI-powered FAB Card Search</text>
  </view>
</view>
