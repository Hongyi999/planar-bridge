<view class="settings-page">
  <text class="page-title font-heading">设置</text>
  <text class="page-subtitle">个性化你的卡牌搜索体验</text>

  <!-- Search preferences -->
  <view class="settings-group">
    <view class="group-title">搜索偏好</view>
    <view class="settings-item" bindtap="onSortPicker">
      <view class="item-left">
        <text class="item-label">默认排序</text>
        <text class="item-desc">{{sortOptions[sortIndex]}}</text>
      </view>
      <text class="item-arrow">›</text>
    </view>
    <view class="settings-item" bindtap="onToggleSearchLang">
      <view class="item-left">
        <text class="item-label">搜索语言</text>
        <text class="item-desc">{{searchLangOptions[searchLangIndex]}}</text>
      </view>
      <text class="item-arrow">›</text>
    </view>
  </view>

  <!-- Display preferences -->
  <view class="settings-group">
    <view class="group-title">显示偏好</view>
    <view class="settings-item" bindtap="onToggleViewMode">
      <view class="item-left">
        <text class="item-label">结果显示方式</text>
        <text class="item-desc">{{viewMode === 'grid' ? '网格视图' : '列表视图'}}</text>
      </view>
      <view class="item-toggle">
        <view class="toggle-btn {{viewMode === 'grid' ? 'active' : ''}}" data-mode="grid" bindtap="onSetViewMode">网格</view>
        <view class="toggle-btn {{viewMode === 'list' ? 'active' : ''}}" data-mode="list" bindtap="onSetViewMode">列表</view>
      </view>
    </view>
    <view class="settings-item" bindtap="onTogglePriceCurrency">
      <view class="item-left">
        <text class="item-label">价格货币</text>
        <text class="item-desc">{{currency === 'USD' ? 'USD ($)' : 'CNY (¥)'}}</text>
      </view>
      <view class="item-toggle">
        <view class="toggle-btn {{currency === 'USD' ? 'active' : ''}}" data-currency="USD" bindtap="onSetCurrency">USD</view>
        <view class="toggle-btn {{currency === 'CNY' ? 'active' : ''}}" data-currency="CNY" bindtap="onSetCurrency">CNY</view>
      </view>
    </view>
  </view>

  <!-- Export settings -->
  <view class="settings-group">
    <view class="group-title">导出设置</view>
    <view class="settings-item-col">
      <text class="item-label">导出字段选择</text>
      <text class="item-desc" style="margin-bottom: 20rpx;">导出收藏时包含以下信息</text>
      <view class="checkbox-grid">
        <view class="checkbox-item" wx:for="{{exportFields}}" wx:key="key" data-key="{{item.key}}" bindtap="onToggleExportField">
          <view class="checkbox-box {{item.checked ? 'checked' : ''}}">
            <view wx:if="{{item.checked}}" class="checkbox-tick"></view>
          </view>
          <text class="checkbox-label">{{item.label}}</text>
        </view>
      </view>
    </view>
    <view class="settings-item" bindtap="onExportCollection">
      <view class="item-left">
        <text class="item-label">导出收藏列表</text>
        <text class="item-desc">复制为文本，可粘贴到备忘录或分享</text>
      </view>
      <text class="item-arrow">›</text>
    </view>
    <view class="settings-item" bindtap="onExportCSV">
      <view class="item-left">
        <text class="item-label">导出为 CSV</text>
        <text class="item-desc">生成表格格式，可用于电子表格</text>
      </view>
      <text class="item-arrow">›</text>
    </view>
  </view>

  <!-- Data management -->
  <view class="settings-group">
    <view class="group-title">数据管理</view>
    <view class="settings-item" bindtap="onClearCache">
      <view class="item-left">
        <text class="item-label">清除缓存</text>
        <text class="item-desc">当前缓存: {{cacheSize}}</text>
      </view>
      <text class="item-arrow">›</text>
    </view>
    <view class="settings-item" bindtap="onResetSettings">
      <view class="item-left">
        <text class="item-label">恢复默认设置</text>
        <text class="item-desc">重置所有偏好设置为初始状态</text>
      </view>
      <text class="item-arrow">›</text>
    </view>
  </view>

  <!-- About -->
  <view class="settings-group">
    <view class="group-title">关于</view>
    <view class="settings-item" bindtap="onAbout">
      <view class="item-left">
        <text class="item-label">关于 Planar Bridge</text>
        <text class="item-desc">版本 {{version}}</text>
      </view>
      <text class="item-arrow">›</text>
    </view>
    <view class="settings-item" bindtap="onFeedback">
      <view class="item-left">
        <text class="item-label">意见反馈</text>
        <text class="item-desc">帮助我们改进产品</text>
      </view>
      <text class="item-arrow">›</text>
    </view>
  </view>

  <!-- Footer -->
  <view class="settings-footer">
    <view class="footer-logo">
      <view class="footer-bridge">
        <view class="fb-left"></view>
        <view class="fb-right"></view>
      </view>
    </view>
    <text class="footer-name font-heading">PLANAR BRIDGE</text>
    <text class="footer-tagline">AI-powered FAB Card Search</text>
  </view>
</view>