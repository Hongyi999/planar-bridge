/* Loading state */
.detail-loading {
  min-height: 100vh;
  background: #F2EFE4;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.loading-dot-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #9B8644;
  animation: dotPulse 1.2s ease-in-out infinite;
}
.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1.2); }
}
.loading-text {
  font-size: 28rpx;
  color: #A09A8C;
}

/* Error state */
.detail-error {
  min-height: 100vh;
  background: #F2EFE4;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.error-text {
  font-size: 32rpx;
  color: #555249;
  margin-bottom: 40rpx;
}
.error-btn {
  padding: 16rpx 48rpx;
  background: #9B8644;
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.detail-page,
.detail-page view,
.detail-page scroll-view {
  box-sizing: border-box;
}

.detail-page .detail-hero {
  box-sizing: content-box;
}

.detail-page {
  min-height: 100vh;
  background: #F2EFE4;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
  width: 100%;
}

/* Hero */
.detail-hero {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  background: #F2EFE4;
  flex-shrink: 0;
}

.deco-circle {
  position: absolute;
  border: 2rpx solid #9B864410;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.deco-1 {
  width: 400rpx;
  height: 400rpx;
}

.deco-2 {
  width: 520rpx;
  height: 520rpx;
  border-color: #9B864408;
}

/* Nav */
.custom-nav {
  position: absolute;
  left: 0;
  right: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  padding-left: 16rpx;
}

.nav-btn-group {
  display: flex;
  align-items: center;
  background: rgba(253, 252, 248, 0.85);
  border: 1rpx solid #D6D0C2;
  overflow: hidden;
  backdrop-filter: blur(10px);
}

.nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn:active { background: rgba(235, 231, 218, 0.6); }

.nav-divider {
  width: 1rpx;
  height: 50%;
  background: #D6D0C2;
}

.nav-icon {
  width: 36rpx;
  height: 36rpx;
}

/* Card visual (image or placeholder) */
.detail-card-visual {
  position: relative;
  z-index: 3;
}

.detail-card-image {
  width: 420rpx;
  height: 588rpx;
  border-radius: 20rpx;
  box-shadow: 0 32rpx 96rpx #9B864420;
}

.detail-card-placeholder {
  width: 420rpx;
  height: 588rpx;
  border-radius: 20rpx;
  border: 4rpx solid #9B864450;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 32rpx 96rpx #9B864420;
  padding: 20rpx;
  text-align: center;
}

.dcp-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #9B8644;
  line-height: 1.3;
  margin-bottom: 4rpx;
}

.dcp-name-cn {
  font-size: 22rpx;
  color: #9B864480;
  margin-bottom: 8rpx;
  font-family: "PingFang SC", -apple-system, sans-serif;
}

.dcp-meta {
  font-size: 18rpx;
  color: #9B864480;
  font-family: -apple-system, "Helvetica Neue", "PingFang SC", sans-serif;
}

/* Handle wrap — sits between hero and sheet */
.sheet-handle-wrap {
  background: #FDFCF8;
  border-radius: 48rpx 48rpx 0 0;
  margin-top: -36rpx;
  position: relative;
  z-index: 5;
  border-top: 2rpx solid #E8E3D8;
  padding: 20rpx 0 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.sheet-handle-bar {
  width: 72rpx;
  height: 8rpx;
  background: #C8C2B4;
  border-radius: 4rpx;
}

/* Sheet */
.detail-sheet {
  background: #FDFCF8;
  flex: 1;
  padding: 0 32rpx 40rpx;
  position: relative;
  z-index: 4;
  box-sizing: border-box;
  overflow-x: hidden;
  width: 100%;
}

/* Hide scrollbar */
.detail-sheet ::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* Header */
.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
  overflow: hidden;
}

.dh-left {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.dh-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C2A22;
  letter-spacing: -0.01em;
  display: block;
  margin-bottom: 2rpx;
  word-break: break-word;
}

.dh-name-cn {
  display: block;
  font-size: 24rpx;
  color: #6B6355;
  margin-bottom: 4rpx;
}

.dh-type {
  font-size: 24rpx;
  color: #A09A8C;
}

.dh-rarity {
  color: #9B8644;
  font-weight: 600;
}

.dh-right {
  text-align: right;
  flex-shrink: 0;
  max-width: 260rpx;
}

.dh-price {
  font-size: 34rpx;
  font-weight: 600;
  display: block;
}

.dh-trend {
  font-size: 20rpx;
  display: block;
  margin-top: 2rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 260rpx;
}

.price-up { color: #3D7A5E; }
.price-down { color: #C4544A; }
.price-flat { color: #A09A8C; }

/* Stat chips */
.stat-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.stat-chip {
  flex: 1;
  background: #F2EFE4;
  border-radius: 20rpx;
  padding: 16rpx 0;
  text-align: center;
  border: 2rpx solid #E8E3D8;
}

.stat-label {
  font-size: 18rpx;
  color: #A09A8C;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  display: block;
  margin-bottom: 4rpx;
}

.stat-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C2A22;
  display: block;
}

.stat-blue {
  color: #4A82B5;
}

/* Card text */
.card-text-box {
  background: #F2EFE4;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid #E8E3D8;
}

.card-text-content {
  font-size: 24rpx;
  line-height: 1.65;
  color: #4A4636;
  white-space: pre-wrap;
  word-break: break-word;
  overflow-wrap: break-word;
}

/* Price row */
.price-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.price-cell {
  flex: 1;
  background: #F2EFE4;
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
  border: 2rpx solid #E8E3D8;
}

.price-label {
  font-size: 18rpx;
  color: #A09A8C;
  display: block;
}

.price-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C2A22;
  display: block;
  margin-top: 4rpx;
}

/* Action row */
.action-row {
  display: flex;
  gap: 16rpx;
}

.action-btn-main {
  flex: 1;
}

.action-btn-link {
  width: 96rpx;
  background: #F2EFE4;
  border: 3rpx solid #D6D0C2;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn-link:active {
  border-color: #9B8644;
}

.link-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

.link-box {
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #6B6355;
  border-radius: 4rpx;
  position: absolute;
  bottom: 0;
  left: 0;
}

.link-arrow {
  position: absolute;
  top: 0;
  right: 0;
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #6B6355;
  border-right: 3rpx solid #6B6355;
}

.bottom-spacer {
  height: 60rpx;
}

/* Collected button style */
.btn-collected {
  background: transparent;
  border: 3rpx solid #9B8644;
  color: #9B8644;
  border-radius: 26rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}
.btn-collected:active {
  background: #9B86440A;
}

/* Multi-select modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-content {
  width: 580rpx;
  background: #FDFCF8;
  border-radius: 32rpx;
  padding: 40rpx 36rpx 32rpx;
  max-height: 70vh;
  overflow-y: auto;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C2A22;
  display: block;
  margin-bottom: 28rpx;
}
.modal-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 32rpx;
}
.modal-list-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
}
.modal-list-item:active {
  background: #F2EFE4;
}
.modal-checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #C8C2B4;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #FDFCF8;
  flex-shrink: 0;
}
.modal-checkbox-checked {
  background: #9B8644;
  border-color: #9B8644;
}
.modal-list-name {
  font-size: 28rpx;
  color: #2C2A22;
  font-weight: 500;
}
.modal-actions {
  display: flex;
  gap: 16rpx;
}
.modal-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 22rpx;
  font-size: 28rpx;
  color: #6B6355;
  background: #F2EFE4;
  font-weight: 500;
}
.modal-btn-cancel:active {
  background: #E8E3D8;
}
.modal-btn-confirm {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 22rpx;
  font-size: 28rpx;
  color: #FDFCF8;
  background: #9B8644;
  font-weight: 600;
}
.modal-btn-confirm:active {
  background: #8B7A3E;
}
