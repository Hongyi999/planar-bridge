<view class="lists-page">
  <!-- Title -->
  <text class="page-title font-heading">我的收藏</text>
  <text class="page-subtitle">{{lists.length}} 个列表 · {{totalCards}} 张卡 · 约 ${{totalValue}}</text>

  <!-- Horizontal scroll list cards -->
  <scroll-view scroll-x class="list-cards-scroll" enhanced show-scrollbar="{{false}}">
    <view class="list-cards-row">
      <view
        wx:for="{{lists}}"
        wx:key="id"
        class="list-card list-card-{{item.color}} {{selectedIndex === index ? 'selected' : ''}}"
        data-index="{{index}}"
        bindtap="onSelectList"
      >
        <text class="lc-name">{{item.name}}</text>
        <text class="lc-count">{{item.cardCount}} 张卡</text>
        <text class="lc-value font-mono">${{item.value}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- Selected list title -->
  <text class="selected-title font-heading" wx:if="{{lists.length > 0}}">{{lists[selectedIndex].name}}</text>

  <!-- Cards list -->
  <view class="cards-list">
    <view
      wx:for="{{selectedCards}}"
      wx:key="id"
      class="card-item"
      data-id="{{item.id}}"
      bindtap="onCardTap"
    >
      <!-- Thumbnail -->
      <view class="ci-thumb" style="background: #EDE9DC">
        <text class="ci-thumb-text font-heading">{{item.name}}</text>
      </view>
      <!-- Info -->
      <view class="ci-info">
        <text class="ci-name font-heading">{{item.name}}</text>
        <text class="ci-meta">{{item.rarityCN || item.rarity}} · {{item.classCN || item.class}} {{item.typeCN || item.type}} · {{item.setCode}}</text>
      </view>
      <!-- Price -->
      <view class="ci-price">
        <text class="ci-price-value font-mono">${{item.priceMid}}</text>
        <text class="ci-trend {{item.priceTrend > 0 ? 'price-up' : item.priceTrend < 0 ? 'price-down' : 'price-flat'}}">
          {{item.priceTrend > 0 ? '▲ ' + item.priceTrend + '%' : item.priceTrend < 0 ? '▼ ' + (-item.priceTrend) + '%' : '— 0%'}}
        </text>
      </view>
    </view>

    <!-- Empty -->
    <view class="empty-list" wx:if="{{selectedCards.length === 0}}">
      <text class="empty-text">此列表暂无卡牌</text>
      <text class="empty-hint">搜索并收藏卡牌，它们会出现在这里</text>
    </view>
  </view>
</view>
