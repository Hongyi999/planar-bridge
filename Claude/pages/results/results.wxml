<view class="results-page">
  <!-- Custom navigation bar -->
  <view class="custom-nav" style="top: {{navTop}}px; height: {{navHeight}}px;">
    <view class="nav-btn-group" style="height: {{navHeight}}px; border-radius: {{navHeight / 2}}px;">
      <view class="nav-btn" style="width: {{navHeight * 1.2}}px; height: {{navHeight}}px;" bindtap="goBack">
        <image class="nav-icon" src="/assets/icons/nav-back.svg" mode="aspectFit" />
      </view>
      <view class="nav-divider"></view>
      <view class="nav-btn" style="width: {{navHeight * 1.2}}px; height: {{navHeight}}px;" bindtap="goHome">
        <image class="nav-icon" src="/assets/icons/nav-home.svg" mode="aspectFit" />
      </view>
    </view>
    <text class="nav-title font-heading">搜索结果</text>
  </view>

  <!-- Scrollable content -->
  <scroll-view scroll-y class="results-scroll" style="padding-top: {{navFullHeight}}px;">
    <!-- Search bar compact -->
    <view class="search-compact">
      <search-bar value="{{query}}" compact="{{true}}" bind:search="onSearch" />
    </view>

    <!-- Thinking strip -->
    <view class="thinking-section">
      <thinking-strip steps="{{thinkingSteps}}" bind:complete="onThinkingComplete" />
    </view>

    <!-- AI Summary -->
    <view class="summary-card {{showResults ? 'show' : ''}}" wx:if="{{summary}}">
      <view class="summary-header">
        <text class="summary-label font-heading">AI 搜索摘要</text>
        <text class="summary-count font-mono">{{resultCount}} 个结果</text>
      </view>
      <text class="summary-text">{{summary}}</text>
    </view>

    <!-- Active filter chips -->
    <view class="filter-chips {{showResults ? 'show' : ''}}" wx:if="{{filterChips.length > 0}}">
      <view class="filter-chip" wx:for="{{filterChips}}" wx:key="key" data-key="{{item.key}}" bindtap="onRemoveChip">
        <text class="fc-label">{{item.label}}:</text>
        <text class="fc-value">{{item.value}}</text>
        <text class="fc-remove">×</text>
      </view>
    </view>

    <!-- Results meta -->
    <view class="results-meta {{showResults ? 'show' : ''}}">
      <text class="meta-left">{{resultCount}} 个结果 · 按价格降序</text>
      <view class="meta-actions">
        <view class="view-toggle" bindtap="onToggleView">
          <image class="view-toggle-icon" src="/assets/icons/{{viewMode === 'grid' ? 'view-list' : 'view-grid'}}.svg" mode="aspectFit" />
        </view>
        <text class="meta-right" bindtap="onFollowUp">继续追问...</text>
      </view>
    </view>

    <!-- Follow-up bar -->
    <view class="followup-bar {{showFollowUp ? 'show' : ''}}" wx:if="{{showFollowUp}}">
      <input class="followup-input" value="{{followUpValue}}"
        placeholder="基于「{{query}}」继续搜索..."
        placeholder-class="followup-placeholder"
        focus="{{showFollowUp}}"
        confirm-type="search"
        bindinput="onFollowUpInput"
        bindconfirm="onFollowUpConfirm" />
      <text class="followup-cancel" bindtap="onFollowUpCancel">取消</text>
    </view>

    <!-- Card grid -->
    <view class="card-grid {{showResults ? 'show' : ''}}" wx:if="{{viewMode === 'grid'}}">
      <card-tile wx:for="{{results}}" wx:key="id" card="{{item}}" index="{{index}}" />
    </view>

    <!-- Card list view -->
    <view class="card-list-view {{showResults ? 'show' : ''}}" wx:if="{{viewMode === 'list'}}">
      <view wx:for="{{results}}" wx:key="id" class="card-list-item" data-id="{{item.id || item._id}}" bindtap="onCardTap">
        <view class="cli-thumb" style="background: #EDE9DC">
          <text class="cli-thumb-text font-heading">{{item.name}}</text>
        </view>
        <view class="cli-info">
          <text class="cli-name font-heading">{{item.name}}</text>
          <text class="cli-name-cn" wx:if="{{item.nameCN}}">{{item.nameCN}}</text>
          <text class="cli-meta">{{item.classCN || item.class}} · {{item.typeCN || item.type}} · {{item.setCode}}</text>
        </view>
        <view class="cli-price">
          <text class="cli-price-value font-mono">${{item.priceMid}}</text>
          <text class="cli-trend {{item.priceTrend > 0 ? 'price-up' : item.priceTrend < 0 ? 'price-down' : 'price-flat'}}">{{item.priceTrend > 0 ? '▲' + item.priceTrend + '%' : item.priceTrend < 0 ? '▼' + (-item.priceTrend) + '%' : '—'}}</text>
        </view>
      </view>
    </view>

    <!-- Empty state — only show after loading completes -->
    <view class="empty-state {{showResults && !isLoading && resultCount === 0 ? 'show' : ''}}" wx:if="{{!isLoading && resultCount === 0}}">
      <text class="empty-text">未找到匹配卡牌</text>
      <text class="empty-hint">尝试其他关键词，如「传奇装备」或「威严攻击」</text>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>
</view>
