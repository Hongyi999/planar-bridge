.results-page,
.results-page view,
.results-page scroll-view {
  box-sizing: border-box;
}

.results-page {
  min-height: 100vh;
  background: #F2EFE4;
  overflow-x: hidden;
  width: 100%;
}

/* Navigation */
.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  padding-left: 16rpx;
  background: #F2EFE4;
}

.nav-btn-group {
  display: flex;
  align-items: center;
  background: rgba(253, 252, 248, 0.85);
  border: 1rpx solid #D6D0C2;
  overflow: hidden;
  z-index: 2;
  backdrop-filter: blur(10px);
}

.nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn:active {
  background: rgba(235, 231, 218, 0.6);
}

.nav-divider {
  width: 1rpx;
  height: 50%;
  background: #D6D0C2;
}

.nav-icon {
  width: 36rpx;
  height: 36rpx;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2A22;
  letter-spacing: 0.04em;
}

/* Content */
.results-scroll {
  height: 100vh;
  padding: 0 28rpx;
}

.search-compact {
  margin-bottom: 32rpx;
  padding-top: 24rpx;
}

.thinking-section {
  margin-bottom: 24rpx;
}

/* Summary */
.summary-card {
  background: #FDFCF8;
  border: 3rpx solid #9B864420;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  opacity: 0;
  transform: translateY(20rpx);
  transition: opacity 0.5s ease-out, transform 0.5s ease-out;
}

.summary-card.show {
  opacity: 1;
  transform: translateY(0);
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #A09A8C;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.summary-count {
  font-size: 24rpx;
  color: #9B8644;
  font-weight: 600;
}

.summary-text {
  font-size: 25rpx;
  color: #4A4636;
  line-height: 1.6;
}

/* Results meta */
.results-meta {
  display: flex;
  justify-content: space-between;
  padding: 0 8rpx;
  margin-bottom: 20rpx;
  opacity: 0;
  transition: opacity 0.4s ease-out;
}

.results-meta.show {
  opacity: 1;
}

.meta-left {
  font-size: 22rpx;
  color: #A09A8C;
}

.meta-right {
  font-size: 22rpx;
  color: #6B4C8A;
  font-weight: 500;
}

/* Follow-up bar */
.followup-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FDFCF8;
  border: 2rpx solid #E8E3D8;
  border-radius: 24rpx;
  padding: 12rpx 20rpx;
  margin-bottom: 20rpx;
  animation: fadeSlideIn 0.3s ease-out;
}

@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.followup-input {
  flex: 1;
  font-size: 26rpx;
  color: #2C2A22;
  min-height: 48rpx;
}

.followup-placeholder {
  color: #C8C2B4;
  font-size: 26rpx;
}

.followup-cancel {
  font-size: 24rpx;
  color: #6B4C8A;
  font-weight: 500;
  flex-shrink: 0;
  padding: 8rpx 16rpx;
}

/* Card grid */
.card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  opacity: 0;
  transition: opacity 0.4s ease-out;
}

.card-grid.show {
  opacity: 1;
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  opacity: 0;
  transition: opacity 0.4s;
}

.empty-state.show {
  opacity: 1;
}

.empty-text {
  display: block;
  font-family: Georgia, "Songti SC", serif;
  font-size: 32rpx;
  color: #6B6355;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #A09A8C;
}

.bottom-spacer {
  height: 60rpx;
}
