.results-page {
  min-height: 100vh;
  background: #F2EFE4;
}

/* Navigation */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  height: 44px;
  padding-left: 24rpx;
  padding-right: 24rpx;
  background: #F2EFE4;
}

.nav-btn-group {
  display: flex;
  align-items: center;
  background: #FDFCF8;
  border: 2rpx solid #D6D0C2;
  border-radius: 32rpx;
  overflow: hidden;
  z-index: 2;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn:active {
  background: #EBE7DA;
}

.nav-divider {
  width: 2rpx;
  height: 28rpx;
  background: #D6D0C2;
}

.nav-arrow-back {
  width: 16rpx;
  height: 16rpx;
  border-left: 3rpx solid #6B6355;
  border-bottom: 3rpx solid #6B6355;
  transform: rotate(45deg);
  margin-left: 4rpx;
}

.nav-home-icon {
  position: relative;
  width: 24rpx;
  height: 22rpx;
}

.home-roof {
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 12rpx solid #6B6355;
  position: absolute;
  top: 0;
  left: -2rpx;
}

.home-body {
  position: absolute;
  bottom: 0;
  left: 3rpx;
  width: 18rpx;
  height: 12rpx;
  border: 2rpx solid #6B6355;
  border-top: none;
  border-radius: 0 0 3rpx 3rpx;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2A22;
  letter-spacing: 0.04em;
}

/* Content */
.results-scroll {
  height: 100vh;
  padding: 0 28rpx;
}

.search-compact {
  margin-bottom: 32rpx;
  padding-top: 24rpx;
}

.thinking-section {
  margin-bottom: 24rpx;
}

/* Summary */
.summary-card {
  background: #FDFCF8;
  border: 3rpx solid #9B864420;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  opacity: 0;
  transform: translateY(20rpx);
  transition: opacity 0.5s ease-out, transform 0.5s ease-out;
}

.summary-card.show {
  opacity: 1;
  transform: translateY(0);
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #A09A8C;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.summary-count {
  font-size: 24rpx;
  color: #9B8644;
  font-weight: 600;
}

.summary-text {
  font-size: 25rpx;
  color: #4A4636;
  line-height: 1.6;
}

/* Results meta */
.results-meta {
  display: flex;
  justify-content: space-between;
  padding: 0 8rpx;
  margin-bottom: 20rpx;
  opacity: 0;
  transition: opacity 0.4s ease-out;
}

.results-meta.show {
  opacity: 1;
}

.meta-left {
  font-size: 22rpx;
  color: #A09A8C;
}

.meta-right {
  font-size: 22rpx;
  color: #6B4C8A;
  font-weight: 500;
}

/* Card grid */
.card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  opacity: 0;
  transition: opacity 0.4s ease-out;
}

.card-grid.show {
  opacity: 1;
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  opacity: 0;
  transition: opacity 0.4s;
}

.empty-state.show {
  opacity: 1;
}

.empty-text {
  display: block;
  font-family: Georgia, "Songti SC", serif;
  font-size: 32rpx;
  color: #6B6355;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #A09A8C;
}

.bottom-spacer {
  height: 60rpx;
}
